# RivalEdge Backend — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk Auth
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_PEM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-your-key

# Scraping
BRAVE_SEARCH_API_KEY=your-brave-key

# Email
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=digest@rivaledge.ai

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SOLO_PRICE_ID=price_1TEYfGLTMdu9rJFPT4iwohw9
STRIPE_PRO_PRICE_ID=price_1TEa3lLTMdu9rJFPgvechLBX

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://rivaledge.ai
